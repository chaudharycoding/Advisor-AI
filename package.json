{
  "name": "advisor-ai",
  "private": true,
  "version": "0.1.0",
  "description": "Academic advising web application with Supabase authentication",
  "type": "module",
  "scripts": {
    "dev": "npx concurrently -n api,agent,vite -c blue,green,magenta \"npm run dev:api\" \"npm run dev:agent\" \"vite\"",
    "dev:web": "npx concurrently -n api,vite -c blue,green \"npm run dev:api\" \"vite\"",
    "dev:vite": "vite",
    "dev:api": "node server/connection-details-server.js",
    "dev:agent": "npm run dev --prefix livekit-voice-agent",
    "dev:self": "npm run dev",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@livekit/components-react": "^2.9.21",
    "@livekit/components-styles": "^1.2.0",
    "@supabase/supabase-js": "^2.39.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "framer-motion": "^12.38.0",
    "livekit-client": "^2.18.9",
    "livekit-server-sdk": "^2.15.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/ui": "^4.1.6",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^6.0.1",
    "vitest": "^4.1.6"
  }
}
