# Supabase Configuration
# Get these values from your Supabase project settings: https://app.supabase.com

VITE_SUPABASE_URL=your-project-url.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# LiveKit — copy into `.env.local` (Advisor-AI root). Same keys as your backend.
# LIVEKIT_URL=wss://advisorai-k4x0lf8v.livekit.cloud
# (The token API normalizes this to https:// for RoomService / AgentDispatch; the browser still gets wss://.)
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# LIVEKIT_ROOM_NAME=roomName
# Must match the voice worker registration (default advisor-voice): LIVEKIT_AGENT_NAME=advisor-voice
# LIVEKIT_SKIP_AGENT_DISPATCH=1
# Default: before each token, remove prior dispatches for LIVEKIT_AGENT_NAME in this room
# so you never stack multiple agents (set LIVEKIT_AGENT_DISPATCH_DEDUP=0 to disable).
# LIVEKIT_AGENT_DISPATCH_DEDUP=0
# Optional: ADVISOR_API_PORT=8787
#
# One `.env.local` at this repo root is enough for `npm run dev` (API + agent both read it).
# Optional `livekit-voice-agent/.env.local` overrides the same keys for the worker only.
