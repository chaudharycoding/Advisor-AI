# Supabase Configuration
# Get these values from your Supabase project settings: https://app.supabase.com
# Project Settings > API > Project URL and Project API keys (anon/public)

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Note: Google OAuth credentials are configured in Supabase Dashboard, not here
# See docs/GOOGLE_OAUTH_SETUP.md for complete setup instructions
